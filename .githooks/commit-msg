#!/bin/sh
# Enforce conventional commits with a REQUIRED scope, so every commit reads the
# same way (no mixing `feat:` and `feat(scope):`). Wired via core.hooksPath,
# which `npm run prepare` sets for you (see package.json).
commit_msg=$(head -1 "$1")

# type(scope): description  — scope is required.
pattern="^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)\(.+\): .{1,}"

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo ""
  echo "❌ Commit message doesn't follow conventional commits format."
  echo ""
  echo "   Expected:  type(scope): description   (scope is required)"
  echo "   Got:       $commit_msg"
  echo ""
  echo "   Types: feat fix docs style refactor perf test build ci chore revert"
  echo "   Examples:"
  echo "     feat(land): reinstall a lane's own node_modules on dep change"
  echo "     fix(build-lock): reclaim a dead holder by PID liveness"
  echo "     chore(deps): update dependencies"
  echo ""
  exit 1
fi
